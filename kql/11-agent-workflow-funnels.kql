// Agent workflow funnel health for Copilot CLI AgentOps.
// Shows how often sessions progress through key workflow stages and where they drop off.
let lookback = 14d;
let base =
AppDependencies
| where TimeGenerated > ago(lookback)
| where (Properties has "github.copilot" or Properties has "gen_ai.operation.name" or Properties has "agentops." or AppRoleName in ("github-copilot", "copilot-chat", "github-copilot-cli", "codex", "openai-codex", "openai-codex-cli") or tostring(Properties["service.name"]) in ("github-copilot", "copilot-chat", "github-copilot-cli", "codex", "openai-codex", "openai-codex-cli") or tostring(Properties["agent.runtime"]) in ("codex", "openai-codex-cli"))
| extend
    conversation = case(
        isnotempty(tostring(Properties["gen_ai.conversation.id"])),
        tostring(Properties["gen_ai.conversation.id"]),
        isnotempty(tostring(Properties["github.copilot.interaction_id"])),
        tostring(Properties["github.copilot.interaction_id"]),
        strcat(
            tostring(Properties["gen_ai.agent.id"]),
            "_",
            tostring(Properties["github.copilot.turn_count"]),
            "_",
            format_datetime(bin(TimeGenerated, 1h), "yyyyMMdd_HHmm")
        )
    ),
    operation = tostring(Properties["gen_ai.operation.name"]),
    model = tostring(Properties["gen_ai.request.model"]),
    agent = tostring(Properties["gen_ai.agent.name"]),
    tool = tostring(Properties["gen_ai.tool.name"]),
    repo = tostring(Properties["agentops.repo.hash"]),
    error = tostring(Properties["error.type"]),
    input_tokens = todouble(Properties["gen_ai.usage.input_tokens"]),
    output_tokens = todouble(Properties["gen_ai.usage.output_tokens"]),
    credits = todouble(Properties["github.copilot.cost"]),
    aiu = todouble(Properties["github.copilot.aiu"]);
let sessions =
base
| summarize
    started = min(TimeGenerated),
    ended = max(TimeGenerated),
    spans = count(),
    has_invoke = countif(operation == "invoke_agent") > 0,
    has_chat = countif(operation == "chat") > 0,
    has_tool = countif(operation == "execute_tool" or isnotempty(tool)) > 0,
    has_tool_failure = countif((operation == "execute_tool" or isnotempty(tool)) and (Success == false or isnotempty(error))) > 0,
    has_any_failure = countif(Success == false or isnotempty(error)) > 0,
    input_tokens = sum(input_tokens),
    output_tokens = sum(output_tokens),
    credits = sum(credits),
    aiu = sum(aiu),
    p95_duration_ms = percentile(DurationMs, 95),
    models = make_set(model, 5),
    agents = make_set(agent, 5),
    tools = make_set(tool, 10),
    repos = make_set(repo, 3),
    errors = make_set(error, 10)
  by conversation;
sessions
| summarize
    sessions = count(),
    invoked = countif(has_invoke),
    chatted = countif(has_chat),
    used_tools = countif(has_tool),
    tool_failed = countif(has_tool_failure),
    any_failed = countif(has_any_failure),
    expensive = countif(credits * 0.01 >= 1.0),
    slow = countif(p95_duration_ms >= 30000),
    high_context = countif(input_tokens >= 30000)
| extend
    invoke_pct = round(100.0 * invoked / sessions, 1),
    chat_pct = round(100.0 * chatted / sessions, 1),
    tool_use_pct = round(100.0 * used_tools / sessions, 1),
    tool_failure_pct = round(100.0 * tool_failed / sessions, 1),
    any_failure_pct = round(100.0 * any_failed / sessions, 1),
    expensive_pct = round(100.0 * expensive / sessions, 1),
    slow_pct = round(100.0 * slow / sessions, 1),
    high_context_pct = round(100.0 * high_context / sessions, 1)
| project
    sessions,
    invoked,
    invoke_pct,
    chatted,
    chat_pct,
    used_tools,
    tool_use_pct,
    tool_failed,
    tool_failure_pct,
    any_failed,
    any_failure_pct,
    expensive,
    expensive_pct,
    slow,
    slow_pct,
    high_context,
    high_context_pct;

// Per-session candidates for workflow tuning.
sessions
| extend
    risk = case(
        has_any_failure, "failed",
        has_tool_failure, "tool_failed",
        credits * 0.01 >= 1.0, "expensive",
        p95_duration_ms >= 30000, "slow",
        input_tokens >= 30000, "high_context",
        "ok"
    ),
    duration_sec = round(datetime_diff("millisecond", ended, started) / 1000.0, 2),
    est_usd = round(credits * 0.01, 4)
| where risk != "ok"
| project
    started,
    conversation,
    risk,
    duration_sec,
    spans,
    p95_duration_ms,
    input_tokens,
    output_tokens,
    credits,
    est_usd,
    aiu,
    models,
    agents,
    tools,
    repos,
    errors
| order by risk asc, est_usd desc, p95_duration_ms desc
| take 100;
