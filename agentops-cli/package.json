{
  "name": "copilot-agentops-cli",
  "version": "0.1.0",
  "description": "Local utilities for Copilot CLI AgentOps for Azure.",
  "files": [
    "README.md",
    "src"
  ],
  "bin": {
    "agentops": "src/index.js"
  },
  "scripts": {
    "test": "node --test",
    "coverage": "node --test --experimental-test-coverage",
    "coverage:check": "node ../scripts/coverage-check.js",
    "static:check": "node ../scripts/static-check.js",
    "publish:check": "node ../scripts/check-cli-publish.js",
    "doctor": "node src/index.js doctor --local-only",
    "scan": "node src/index.js scan"
  },
  "engines": {
    "node": ">=20"
  },
