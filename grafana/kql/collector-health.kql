union isfuzzy=true AgentOpsCollectorHealth_CL
| where TimeGenerated between ($__timeFrom() .. $__timeTo())
| project
    TimeGenerated,
    CheckName,
    Status,
    Detail,
    PrivacyMode,
    CollectorMode,
    OtlpEndpoint,
    AzureConfigured,
    GrafanaConfigured,
    DashboardVersion,
    SchemaVersion,
    ExportErrors,
    ExportFailureReason,
    ExportFailureAction,
    DroppedContentCount,
    LastSpanReceived,
    LastExportSuccess
| order by TimeGenerated desc
