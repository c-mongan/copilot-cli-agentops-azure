union isfuzzy=true AgentOpsRunSummary_CL
| where TimeGenerated between ($__timeFrom() .. $__timeTo())
| extend SkillName=tostring(column_ifexists("SkillName", ""))
| extend ParentAgentName=tostring(column_ifexists("ParentAgentName", ""))
| extend SubAgentName=tostring(column_ifexists("SubAgentName", ""))
| extend DelegationId=tostring(column_ifexists("DelegationId", ""))
| project
    TimeGenerated,
    RunId,
    SessionId,
    TraceId,
    Surface,
    RepoHash,
    TaskType,
    AgentName,
    SkillName,
    ParentAgentName,
    SubAgentName,
    DelegationId,
    ModelActual,
    OutcomeStatus,
    OutcomeReason,
    DurationMs,
    InputTokens,
    OutputTokens,
    EstimatedCostUsd,
    ToolCount,
    ToolFailureCount,
    ToolDeniedCount,
    TestsRan,
    TestsPassed,
    PrOpened,
    EvalOverall,
    RiskScore
| order by TimeGenerated desc
