{
  "version": 1,
  "hooks": {
    "preToolUse": [
      {
        "type": "command",
        "bash": "node scripts/pre-tool-policy.js",
        "powershell": "node scripts/pre-tool-policy.js",
        "timeoutSec": 5
      }
    ],
    "postToolUseFailure": [
      {
        "type": "command",
        "bash": "node scripts/post-tool-failure-hints.js",
        "powershell": "node scripts/post-tool-failure-hints.js",
        "timeoutSec": 5
      }
    ],
    "agentStop": [
      {
        "type": "command",
        "bash": "node scripts/agent-stop-quality-gate.js",
        "powershell": "node scripts/agent-stop-quality-gate.js",
        "timeoutSec": 5
      }
    ],
    "subagentStop": [
      {
        "type": "command",
        "bash": "node scripts/agent-stop-quality-gate.js",
        "powershell": "node scripts/agent-stop-quality-gate.js",
        "timeoutSec": 5
      }
    ],
    "notification": [
      {
        "type": "command",
        "bash": "node scripts/emit-sidecar-event.js",
        "powershell": "node scripts/emit-sidecar-event.js",
        "timeoutSec": 2
      }
    ]
  }
}
