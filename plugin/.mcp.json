{
  "mcpServers": {
    "azure-mcp": {
      "tools": [
        "*"
      ],
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@azure/mcp@latest",
        "server",
        "start",
        "--read-only",
        "--namespace",
        "monitor"
      ]
    }
  }
}
