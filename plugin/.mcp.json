{
  "mcpServers": {
    "azure-mcp": {
      "tools": [
        "*"
      ],
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@azure/mcp@latest",
        "server",
        "start",
        "--read-only",
        "--namespace",
        "monitor"
      ]
    },
    "microsoft-learn": {
      "tools": [
        "microsoft_docs_search",
        "microsoft_docs_fetch",
        "microsoft_code_sample_search"
      ],
      "type": "http",
      "url": "https://learn.microsoft.com/api/mcp"
    }
  }
}
