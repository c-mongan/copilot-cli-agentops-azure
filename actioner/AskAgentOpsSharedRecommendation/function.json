{
  "bindings": [
    {
      "authLevel": "function",
      "type": "httpTrigger",
      "direction": "in",
      "name": "req",
      "methods": ["get"],
      "route": "ask-agentops/shared/recommendation/{recommendation_blob_id}"
    },
    {
      "type": "blob",
      "direction": "in",
      "name": "recommendationBlob",
      "path": "%AGENTOPS_SHARED_STORE_CONTAINER%/%AGENTOPS_SHARED_STORE_PREFIX%/AgentOpsRecommendations_CL/{recommendation_blob_id}.json",
      "connection": "AgentOpsSharedStorage"
    },
    {
      "type": "http",
      "direction": "out",
      "name": "res"
    }
  ],
  "scriptFile": "../index.js",
  "entryPoint": "askAgentOps"
}
