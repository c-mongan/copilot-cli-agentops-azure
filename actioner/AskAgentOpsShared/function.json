{
  "bindings": [
    {
      "authLevel": "function",
      "type": "httpTrigger",
      "direction": "in",
      "name": "req",
      "methods": ["post"],
      "route": "ask-agentops/shared"
    },
    {
      "type": "blob",
      "direction": "in",
      "name": "recommendationBlob",
      "path": "%AGENTOPS_SHARED_STORE_CONTAINER%/%AGENTOPS_SHARED_STORE_PREFIX%/AgentOpsRecommendations_CL/{recommendation_blob_id}.json",
      "connection": "AgentOpsSharedStorage"
    },
    {
      "type": "blob",
      "direction": "in",
      "name": "savedViewBlob",
      "path": "%AGENTOPS_SHARED_STORE_CONTAINER%/%AGENTOPS_SHARED_STORE_PREFIX%/AgentOpsSavedViews_CL/{saved_view_blob_id}.json",
      "connection": "AgentOpsSharedStorage"
    },
    {
      "type": "blob",
      "direction": "in",
      "name": "alertHandoffBlob",
      "path": "%AGENTOPS_SHARED_STORE_CONTAINER%/%AGENTOPS_SHARED_STORE_PREFIX%/AgentOpsAlertHandoffs/{alert_handoff_blob_id}.json",
      "connection": "AgentOpsSharedStorage"
    },
    {
      "type": "http",
      "direction": "out",
      "name": "res"
    }
  ],
  "scriptFile": "../index.js",
  "entryPoint": "askAgentOps"
}
